<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="1771282318547-1" author="Szymon Wierzchoś">
        <createTable tableName="addresses">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>

            <column name="street" type="VARCHAR(100)"/>
            <column name="building_number" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="apartment_number" type="VARCHAR(10)"/>
            <column name="city" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="zip_code" type="VARCHAR(12)">
                <constraints nullable="false"/>
            </column>
            <column name="country" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            
        </createTable>

        <createTable tableName="patients">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>

            <column name="address_id" type="BIGINT">
                <constraints unique="true" foreignKeyName="fk_patient_address" references="addresses(id)"/>
            </column>
            <column name="first_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="pesel" type="VARCHAR(11)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_patient_pesel"/>
            </column>
            <column name="date_of_birth" type="DATE"/>
            <column name="email" type="VARCHAR(100)"/>
            <column name="phone_number" type="VARCHAR(20)"/>
            <column name="gender" type="VARCHAR(6)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="doctors">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>

            <column name="address_id" type="BIGINT">
                <constraints unique="true" foreignKeyName="fk_doctor_address" references="addresses(id)"/>
            </column>
            <column name="first_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="license_number" type="VARCHAR(7)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_doctor_license_number"/>
            </column>
            <column name="specialization" type="VARCHAR(100)"/>
            <column name="phone_number" type="VARCHAR(20)"/>
            <column name="email" type="VARCHAR(100)"/>
            <column name="gender" type="VARCHAR(6)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="medical_records">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>
            <column name="symptoms" type="TEXT"/>
            <column name="physical_examination" type="TEXT"/>
            <column name="diagnosis" type="TEXT"/>
            <column name="recommendations" type="TEXT"/>
        </createTable>

        <createTable tableName="visit">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>

            <column name="patient_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_visit_patient" references="patients(id)"/>
            </column>
            <column name="doctor_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_visit_doctor" references="doctors(id)"/>
            </column>
            <column name="visit_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="status"  type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="reason"  type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="medical_record_id" type="BIGINT">
                    <constraints unique="true" foreignKeyName="fk_visit_medical_record" references="medical_records(id)"/>
            </column>
        </createTable>

        <createTable tableName="prescriptions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>

            <column name="visit_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_prescription_visit"
                             references="visit(id)"/>
            </column>
            <column name="medication_name" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="dosage" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="duration_days" type="INT"/>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="access_code" type="VARCHAR(4)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="lab_orders">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>

            <column name="visit_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_lab_order_visit"
                             references="visit(id)"/>
            </column>
            <column name="test_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="access_code" type="VARCHAR(4)">
                <constraints nullable="false"/>
            </column>
            <column name="result_pdf_url" type="VARCHAR(255)"/>
        </createTable>

    </changeSet>

</databaseChangeLog>